<link rel="stylesheet" href="{{ 'volt-global.css' | asset_url }}">

<div class="volt-page">
  <section class="volt-section" style="min-height:70vh; display:flex; align-items:center;">
    <div class="volt-container">
      <div class="volt-empty">
        <div class="volt-404__code">
          {% for block in section.blocks %}
            {% if block.type == 'glitch_line' %}
              <div class="volt-404__glitch-line" {{ block.shopify_attributes }}
                   style="font-family:var(--font-mono); font-size:12px; color:rgba(255,255,255,0.15); letter-spacing:0.2em;">
                {{ block.settings.text }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="volt-banner__label" style="justify-content:center; margin-bottom:20px;">{{ section.settings.label | default: '// ERROR_404' }}</div>
        <h1 style="font-family:var(--font-display); font-size:clamp(100px, 20vw, 200px); font-weight:600; color:var(--color-white); line-height:0.85; margin:0; font-style:italic;">
          {{ section.settings.error_code | default: '404' }}
        </h1>
        <h2 class="volt-empty__title" style="margin-top:16px;">{{ section.settings.heading | default: 'SIGNAL LOST' }}</h2>
        <p class="volt-empty__text">{{ section.settings.description | default: 'The page you are looking for has been disconnected or never existed.' }}</p>
        <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
          <a href="/" class="volt-btn">{{ section.settings.home_button | default: 'RETURN HOME' }}</a>
          <a href="/collections/all" class="volt-btn volt-btn--outline">{{ section.settings.shop_button | default: 'BROWSE PRODUCTS' }}</a>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .volt-404__code { margin-bottom: 20px; }
</style>

{% schema %}
{
  "name": "Volt 404",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Error Label",
      "default": "// ERROR_404"
    },
    {
      "type": "text",
      "id": "error_code",
      "label": "Error Code",
      "default": "404"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SIGNAL LOST"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "The page you are looking for has been disconnected or never existed."
    },
    {
      "type": "text",
      "id": "home_button",
      "label": "Home Button Text",
      "default": "RETURN HOME"
    },
    {
      "type": "text",
      "id": "shop_button",
      "label": "Shop Button Text",
      "default": "BROWSE PRODUCTS"
    }
  ],
  "blocks": [
    {
      "type": "glitch_line",
      "name": "Glitch Text Line",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "ERR::CONNECTION_REFUSED // PACKET_LOSS:100%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Volt 404",
      "blocks": [
        { "type": "glitch_line", "settings": { "text": "ERR::CONNECTION_REFUSED // PACKET_LOSS:100%" } },
        { "type": "glitch_line", "settings": { "text": "TRACE: 0x00000000 >> NULL_POINTER_EXCEPTION" } },
        { "type": "glitch_line", "settings": { "text": "FATAL: ROUTE_NOT_FOUND // RETRY_FAILED" } }
      ]
    }
  ]
}
{% endschema %}
