<link rel="stylesheet" href="{{ 'volt-global.css' | asset_url }}">

<div class="volt-page">
  <div class="volt-banner">
    <div class="volt-container">
      <div class="volt-banner__label">{{ section.settings.label | default: '// SEARCH_QUERY' }}</div>
      <h1 class="volt-banner__title">{{ section.settings.heading | default: 'SEARCH' }}</h1>

      <form action="{{ routes.search_url }}" method="get" role="search" style="margin-top:30px; max-width:600px;">
        <div style="display:flex; gap:0;">
          <input type="search" name="q" value="{{ search.terms | escape }}" class="volt-input" placeholder="{{ section.settings.placeholder | default: 'Search products, articles...' }}" style="flex:1;">
          <button type="submit" class="volt-btn" style="clip-path:none;">{{ section.settings.search_button | default: 'SCAN' }}</button>
        </div>
      </form>
    </div>
  </div>

  <section class="volt-section">
    <div class="volt-container">
      {% if search.performed %}
        <p style="font-family:var(--font-mono); font-size:13px; color:rgba(255,255,255,0.5); margin-bottom:40px;">
          {{ search.results_count }} {{ section.settings.results_label | default: 'RESULTS FOR' }} "{{ search.terms }}"
        </p>

        {% if search.results.size > 0 %}
          {% paginate search.results by section.settings.results_per_page | default: 12 %}
            <div class="volt-grid volt-grid--{{ section.settings.columns | default: 4 }}">
              {% for item in search.results %}
                <a href="{{ item.url }}" class="volt-card" style="text-decoration:none;">
                  {% if item.featured_image %}
                    <img src="{{ item.featured_image | image_url: width: 400 }}" alt="{{ item.title | escape }}"
                         style="width:100%; height:200px; object-fit:{% if item.object_type == 'product' %}contain{% else %}cover{% endif %}; filter:{% if item.object_type == 'article' %}grayscale(50%){% else %}none{% endif %};">
                  {% endif %}
                  <div style="margin-top:16px;">
                    <span class="volt-tag" style="margin-bottom:8px;">{{ item.object_type | upcase }}</span>
                    <h3 style="font-family:var(--font-display); font-size:22px; color:var(--color-white); text-transform:uppercase; margin:8px 0 0;">{{ item.title }}</h3>
                    {% if item.object_type == 'product' %}
                      <p style="font-family:var(--font-mono); font-size:16px; color:var(--color-neon-green); margin-top:6px; font-weight:700;">{{ item.price | money }}</p>
                    {% elsif item.object_type == 'article' %}
                      <p style="font-family:var(--font-sans); font-size:13px; color:rgba(255,255,255,0.5); margin-top:6px;">{{ item.content | strip_html | truncate: 100 }}</p>
                    {% endif %}
                  </div>
                </a>
              {% endfor %}
            </div>

            {% if paginate.pages > 1 %}
              <div class="volt-pagination">
                {% if paginate.previous %}<a href="{{ paginate.previous.url }}">&larr;</a>{% endif %}
                {% for part in paginate.parts %}
                  {% if part.is_link %}
                    <a href="{{ part.url }}">{{ part.title }}</a>
                  {% else %}
                    <span class="current">{{ part.title }}</span>
                  {% endif %}
                {% endfor %}
                {% if paginate.next %}<a href="{{ paginate.next.url }}">&rarr;</a>{% endif %}
              </div>
            {% endif %}
          {% endpaginate %}
        {% else %}
          <div class="volt-empty">
            <div class="volt-empty__icon">&#128269;</div>
            <h2 class="volt-empty__title">{{ section.settings.no_results_heading | default: 'NO RESULTS' }}</h2>
            <p class="volt-empty__text">{{ section.settings.no_results_text | default: 'Try a different search term.' }}</p>
          </div>
        {% endif %}
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Volt Search",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Banner Label",
      "default": "// SEARCH_QUERY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page Heading",
      "default": "SEARCH"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Search Placeholder",
      "default": "Search products, articles..."
    },
    {
      "type": "text",
      "id": "search_button",
      "label": "Search Button Text",
      "default": "SCAN"
    },
    {
      "type": "text",
      "id": "results_label",
      "label": "Results Label",
      "default": "RESULTS FOR"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Grid Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results Per Page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    },
    {
      "type": "header",
      "content": "No Results"
    },
    {
      "type": "text",
      "id": "no_results_heading",
      "label": "No Results Heading",
      "default": "NO RESULTS"
    },
    {
      "type": "text",
      "id": "no_results_text",
      "label": "No Results Text",
      "default": "Try a different search term."
    }
  ],
  "presets": [
    {
      "name": "Volt Search"
    }
  ]
}
{% endschema %}
