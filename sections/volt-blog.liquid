<link rel="stylesheet" href="{{ 'volt-global.css' | asset_url }}">

<div class="volt-page">
  <div class="volt-banner">
    <div class="volt-container">
      <div class="volt-banner__label">{{ section.settings.label | default: '// TRANSMISSIONS' }}</div>
      <h1 class="volt-banner__title">{{ blog.title }}</h1>
      {% if section.settings.description != blank %}
        <div class="volt-banner__description">{{ section.settings.description }}</div>
      {% endif %}
    </div>
  </div>

  <!-- Tags Filter -->
  {% if blog.all_tags.size > 0 and section.settings.show_tags %}
    <div class="volt-container" style="padding-top:24px; padding-bottom:24px; border-bottom:1px solid rgba(255,255,255,0.1);">
      <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <a href="{{ blog.url }}" class="volt-tag {% unless current_tags %}active{% endunless %}" style="text-decoration:none; {% unless current_tags %}border-color:var(--color-neon-green); color:var(--color-neon-green);{% endunless %}">ALL</a>
        {% for tag in blog.all_tags %}
          {% if current_tags contains tag %}
            <a href="{{ blog.url }}" class="volt-tag active" style="text-decoration:none; border-color:var(--color-neon-green); color:var(--color-neon-green);">{{ tag }}</a>
          {% else %}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="volt-tag" style="text-decoration:none;">{{ tag }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <section class="volt-section">
    <div class="volt-container">
      {% paginate blog.articles by section.settings.articles_per_page | default: 6 %}
        {% if blog.articles.size > 0 %}
          <div class="volt-grid volt-grid--{{ section.settings.columns | default: 3 }}">
            {% for article in blog.articles %}
              <a href="{{ article.url }}" class="volt-card volt-blog-card" style="text-decoration:none;">
                {% if article.image %}
                  <div class="volt-blog-card__image">
                    <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" style="width:100%; height:250px; object-fit:cover; filter:grayscale(60%) contrast(1.1); transition:filter 0.3s;">
                  </div>
                {% endif %}
                <div style="padding:8px 0 0;">
                  {% if section.settings.show_date %}
                    <p style="font-family:var(--font-mono); font-size:11px; color:rgba(255,255,255,0.4); margin:0 0 8px;">
                      {{ article.published_at | date: '%b %d, %Y' | upcase }}
                    </p>
                  {% endif %}
                  <h3 style="font-family:var(--font-display); font-size:28px; color:var(--color-white); text-transform:uppercase; margin:0 0 8px; line-height:1;">{{ article.title }}</h3>
                  {% if section.settings.show_excerpt and article.excerpt != blank %}
                    <p style="font-family:var(--font-sans); font-size:14px; color:rgba(255,255,255,0.5); line-height:1.5; margin:0;">{{ article.excerpt | strip_html | truncate: 120 }}</p>
                  {% endif %}
                  <span style="font-family:var(--font-mono); font-size:12px; color:var(--color-neon-green); display:inline-block; margin-top:12px;">
                    {{ section.settings.read_more_text | default: 'READ MORE' }} &rarr;
                  </span>
                </div>
              </a>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="volt-pagination">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}">&larr;</a>
              {% endif %}
              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {% else %}
                  <span class="current">{{ part.title }}</span>
                {% endif %}
              {% endfor %}
              {% if paginate.next %}
                <a href="{{ paginate.next.url }}">&rarr;</a>
              {% endif %}
            </div>
          {% endif %}
        {% else %}
          <div class="volt-empty">
            <div class="volt-empty__icon">&#128221;</div>
            <h2 class="volt-empty__title">{{ section.settings.empty_heading | default: 'NO POSTS YET' }}</h2>
            <p class="volt-empty__text">{{ section.settings.empty_text | default: 'Check back soon for updates.' }}</p>
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  </section>
</div>

<style>
  .volt-blog-card:hover img { filter: grayscale(0%) contrast(1) !important; }
</style>

{% schema %}
{
  "name": "Volt Blog",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Banner Label",
      "default": "// TRANSMISSIONS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Blog Description"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Grid Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles Per Page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show Tag Filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show Excerpt",
      "default": true
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read More Text",
      "default": "READ MORE"
    },
    {
      "type": "header",
      "content": "Empty State"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Empty Heading",
      "default": "NO POSTS YET"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty Text",
      "default": "Check back soon for updates."
    }
  ],
  "presets": [
    {
      "name": "Volt Blog"
    }
  ]
}
{% endschema %}
