<link rel="stylesheet" href="{{ 'volt-global.css' | asset_url }}">

<div class="volt-page">
  <div class="volt-banner">
    <div class="volt-container">
      <div class="volt-banner__label">{{ section.settings.label | default: '// CHECKOUT' }}</div>
      <h1 class="volt-banner__title">{{ section.settings.heading | default: 'YOUR CART' }}</h1>
    </div>
  </div>

  <section class="volt-section">
    <div class="volt-container">
      {% if cart.item_count > 0 %}
        <form action="/cart" method="post" novalidate>
          <!-- Cart Header -->
          <div class="volt-cart__header">
            <span>{{ section.settings.col_product | default: 'PRODUCT' }}</span>
            <span>{{ section.settings.col_quantity | default: 'QTY' }}</span>
            <span>{{ section.settings.col_total | default: 'TOTAL' }}</span>
          </div>

          <!-- Cart Items -->
          {% for item in cart.items %}
            <div class="volt-cart__item">
              <div class="volt-cart__item-info">
                <a href="{{ item.url }}">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}" class="volt-cart__item-img">
                  {% endif %}
                </a>
                <div>
                  <a href="{{ item.url }}" class="volt-cart__item-title">{{ item.product.title }}</a>
                  {% unless item.product.has_only_default_variant %}
                    <p class="volt-cart__item-variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  <p class="volt-cart__item-price">{{ item.original_price | money }}</p>
                </div>
              </div>
              <div class="volt-qty">
                <button type="button" onclick="voltUpdateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})">-</button>
                <input type="text" value="{{ item.quantity }}" readonly>
                <button type="button" onclick="voltUpdateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
              </div>
              <div class="volt-cart__item-total">
                <span>{{ item.final_line_price | money }}</span>
                <button type="button" class="volt-cart__remove" onclick="voltUpdateQty('{{ item.key }}', 0)">
                  {{ section.settings.remove_text | default: 'REMOVE' }}
                </button>
              </div>
            </div>
          {% endfor %}

          <hr class="volt-divider">

          <!-- Cart Footer -->
          <div class="volt-cart__footer">
            {% for block in section.blocks %}
              {% if block.type == 'note' %}
                <div class="volt-cart__note" {{ block.shopify_attributes }}>
                  <label class="volt-label" for="cart-note">{{ block.settings.note_label | default: 'ORDER NOTES' }}</label>
                  <textarea id="cart-note" name="note" class="volt-textarea" style="min-height:80px;" placeholder="{{ block.settings.note_placeholder | default: 'Special instructions...' }}">{{ cart.note }}</textarea>
                </div>
              {% endif %}
            {% endfor %}

            <div class="volt-cart__summary">
              <div class="volt-cart__subtotal">
                <span class="volt-cart__subtotal-label">{{ section.settings.subtotal_label | default: 'SUBTOTAL' }}</span>
                <span class="volt-cart__subtotal-value">{{ cart.total_price | money }}</span>
              </div>
              <p style="font-family:var(--font-mono); font-size:12px; color:rgba(255,255,255,0.4); margin:8px 0 24px; text-align:right;">
                {{ section.settings.tax_note | default: 'Taxes and shipping calculated at checkout' }}
              </p>
              <button type="submit" name="checkout" class="volt-btn" style="width:100%;">
                {{ section.settings.checkout_text | default: 'PROCEED TO CHECKOUT' }}
              </button>
              <a href="/collections/all" class="volt-btn volt-btn--outline" style="width:100%; margin-top:12px; text-align:center;">
                {{ section.settings.continue_text | default: 'CONTINUE SHOPPING' }}
              </a>
            </div>
          </div>
        </form>
      {% else %}
        <div class="volt-empty">
          <div class="volt-empty__icon">&#128722;</div>
          <h2 class="volt-empty__title">{{ section.settings.empty_heading | default: 'CART EMPTY' }}</h2>
          <p class="volt-empty__text">{{ section.settings.empty_text | default: 'Your cart is currently empty.' }}</p>
          <a href="/collections/all" class="volt-btn">{{ section.settings.empty_button | default: 'START SHOPPING' }}</a>
        </div>
      {% endif %}
    </div>
  </section>
</div>

<style>
  .volt-cart__header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 20px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .volt-cart__header span:last-child { text-align: right; }
  .volt-cart__item {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 20px;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .volt-cart__item-info {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .volt-cart__item-img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    background: var(--color-charcoal);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .volt-cart__item-title {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--color-white);
    text-decoration: none;
    text-transform: uppercase;
  }
  .volt-cart__item-variant {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    margin: 4px 0 0;
  }
  .volt-cart__item-price {
    font-family: var(--font-mono);
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    margin: 4px 0 0;
  }
  .volt-cart__item-total {
    text-align: right;
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--color-white);
    font-weight: 700;
  }
  .volt-cart__remove {
    display: block;
    background: none;
    border: none;
    color: rgba(255,255,255,0.3);
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: pointer;
    margin-top: 8px;
    transition: color 0.2s;
    margin-left: auto;
  }
  .volt-cart__remove:hover { color: #ff4444; }
  .volt-cart__footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 40px;
  }
  .volt-cart__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .volt-cart__subtotal-label {
    font-family: var(--font-mono);
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
  }
  .volt-cart__subtotal-value {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 600;
    color: var(--color-neon-green);
  }
  @media (max-width: 768px) {
    .volt-cart__header { display: none; }
    .volt-cart__item { grid-template-columns: 1fr; gap: 12px; }
    .volt-cart__item-total { text-align: left; }
    .volt-cart__remove { margin-left: 0; }
    .volt-cart__footer { grid-template-columns: 1fr; }
  }
</style>

<script>
  function voltUpdateQty(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(() => window.location.reload());
  }
</script>

{% schema %}
{
  "name": "Volt Cart",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Banner Label",
      "default": "// CHECKOUT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page Heading",
      "default": "YOUR CART"
    },
    {
      "type": "header",
      "content": "Column Headers"
    },
    {
      "type": "text",
      "id": "col_product",
      "label": "Product Column",
      "default": "PRODUCT"
    },
    {
      "type": "text",
      "id": "col_quantity",
      "label": "Quantity Column",
      "default": "QTY"
    },
    {
      "type": "text",
      "id": "col_total",
      "label": "Total Column",
      "default": "TOTAL"
    },
    {
      "type": "text",
      "id": "remove_text",
      "label": "Remove Text",
      "default": "REMOVE"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "text",
      "id": "subtotal_label",
      "label": "Subtotal Label",
      "default": "SUBTOTAL"
    },
    {
      "type": "text",
      "id": "tax_note",
      "label": "Tax Note",
      "default": "Taxes and shipping calculated at checkout"
    },
    {
      "type": "text",
      "id": "checkout_text",
      "label": "Checkout Button",
      "default": "PROCEED TO CHECKOUT"
    },
    {
      "type": "text",
      "id": "continue_text",
      "label": "Continue Shopping Button",
      "default": "CONTINUE SHOPPING"
    },
    {
      "type": "header",
      "content": "Empty State"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Empty Heading",
      "default": "CART EMPTY"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty Text",
      "default": "Your cart is currently empty."
    },
    {
      "type": "text",
      "id": "empty_button",
      "label": "Empty Button Text",
      "default": "START SHOPPING"
    }
  ],
  "blocks": [
    {
      "type": "note",
      "name": "Order Notes",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "note_label",
          "label": "Note Label",
          "default": "ORDER NOTES"
        },
        {
          "type": "text",
          "id": "note_placeholder",
          "label": "Note Placeholder",
          "default": "Special instructions..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Volt Cart",
      "blocks": [
        { "type": "note" }
      ]
    }
  ]
}
{% endschema %}
