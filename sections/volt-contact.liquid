<link rel="stylesheet" href="{{ 'volt-global.css' | asset_url }}">

<div class="volt-page">
  <div class="volt-banner">
    <div class="volt-container">
      <div class="volt-banner__label">{{ section.settings.label | default: '// CONTACT' }}</div>
      <h1 class="volt-banner__title">{{ section.settings.heading | default: 'GET IN TOUCH' }}</h1>
      {% if section.settings.description != blank %}
        <div class="volt-banner__description">{{ section.settings.description }}</div>
      {% endif %}
    </div>
  </div>

  <section class="volt-section">
    <div class="volt-container">
      <div class="volt-contact-layout">
        <!-- Contact Form -->
        <div>
          {% form 'contact' %}
            {% if form.posted_successfully? %}
              <div style="padding:20px; border:1px solid var(--color-neon-green); margin-bottom:30px; font-family:var(--font-mono); font-size:14px; color:var(--color-neon-green);">
                {{ section.settings.success_message | default: 'MESSAGE SENT SUCCESSFULLY. WE WILL RESPOND SHORTLY.' }}
              </div>
            {% endif %}
            {% if form.errors %}
              <div style="padding:20px; border:1px solid #ff4444; margin-bottom:30px; font-family:var(--font-mono); font-size:13px; color:#ff4444;">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;">
              <div>
                <label class="volt-label" for="contact-name">{{ section.settings.name_label | default: 'NAME' }}</label>
                <input type="text" id="contact-name" name="contact[{{ 'templates.contact.form.name' | t }}]" class="volt-input" required>
              </div>
              <div>
                <label class="volt-label" for="contact-email">{{ section.settings.email_label | default: 'EMAIL' }}</label>
                <input type="email" id="contact-email" name="contact[email]" class="volt-input" autocomplete="email" required>
              </div>
            </div>

            {% if section.settings.show_phone %}
              <div style="margin-bottom:20px;">
                <label class="volt-label" for="contact-phone">{{ section.settings.phone_label | default: 'PHONE' }}</label>
                <input type="tel" id="contact-phone" name="contact[{{ 'templates.contact.form.phone' | t }}]" class="volt-input">
              </div>
            {% endif %}

            <div style="margin-bottom:20px;">
              <label class="volt-label" for="contact-message">{{ section.settings.message_label | default: 'MESSAGE' }}</label>
              <textarea id="contact-message" name="contact[{{ 'templates.contact.form.comment' | t }}]" class="volt-textarea" required></textarea>
            </div>

            <button type="submit" class="volt-btn">{{ section.settings.submit_text | default: 'SEND MESSAGE' }}</button>
          {% endform %}
        </div>

        <!-- Contact Info -->
        <div>
          {% for block in section.blocks %}
            {% if block.type == 'info_block' %}
              <div class="volt-card" style="margin-bottom:16px;" {{ block.shopify_attributes }}>
                <h4 style="font-family:var(--font-mono); font-size:12px; color:var(--color-neon-green); text-transform:uppercase; margin:0 0 8px;">{{ block.settings.block_label }}</h4>
                <p style="font-family:var(--font-sans); font-size:15px; color:rgba(255,255,255,0.8); margin:0; line-height:1.6;">{{ block.settings.block_content }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .volt-contact-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 60px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .volt-contact-layout { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

{% schema %}
{
  "name": "Volt Contact",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Banner Label",
      "default": "// CONTACT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page Heading",
      "default": "GET IN TOUCH"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Form Fields"
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "Name Label",
      "default": "NAME"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email Label",
      "default": "EMAIL"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show Phone Field",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone Label",
      "default": "PHONE"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Message Label",
      "default": "MESSAGE"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit Button Text",
      "default": "SEND MESSAGE"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "MESSAGE SENT SUCCESSFULLY. WE WILL RESPOND SHORTLY."
    }
  ],
  "blocks": [
    {
      "type": "info_block",
      "name": "Contact Info",
      "settings": [
        {
          "type": "text",
          "id": "block_label",
          "label": "Label",
          "default": "// EMAIL"
        },
        {
          "type": "textarea",
          "id": "block_content",
          "label": "Content",
          "default": "hello@voltenergy.com"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Volt Contact",
      "blocks": [
        { "type": "info_block", "settings": { "block_label": "// EMAIL", "block_content": "hello@voltenergy.com" } },
        { "type": "info_block", "settings": { "block_label": "// HEADQUARTERS", "block_content": "Los Angeles, California" } },
        { "type": "info_block", "settings": { "block_label": "// RESPONSE TIME", "block_content": "Within 24 hours" } }
      ]
    }
  ]
}
{% endschema %}
