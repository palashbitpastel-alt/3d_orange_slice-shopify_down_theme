<link rel="stylesheet" href="{{ 'products.css' | asset_url }}">
<script type="module" src="https://cdn.shopify.com/storefront/web-components.js"></script>

<section id="products" class="products-section">
    <div class="container-volt">
        <div class="section-header">
            <div>
                <div class="section-label">{{ section.settings.label | default: '// CATALOG_V1.0' }}</div>
                <h2 class="section-headline">{{ section.settings.heading | default: 'SELECT FUEL' }}</h2>
            </div>
        </div>

        <div class="products-grid">
            {% if section.settings.storefront_domain != blank and section.settings.storefront_token != blank %}
              <shopify-store store-domain="{{ section.settings.storefront_domain }}" public-access-token="{{ section.settings.storefront_token }}" country="{{ section.settings.storefront_country | default: 'US' }}">
                  <shopify-cart id="cart"></shopify-cart>
                  <shopify-list-context type="product" query="products" first="{{ section.settings.products_count | default: 3 }}">
                      <template>
                          <div class="product-card">
                              <a shopify-attr--href="'/products/' + product.handle" style="text-decoration:none;">
                                  <img src="https://images.unsplash.com/photo-1622543925917-095a35c9704d?q=80&w=600&auto=format&fit=crop" class="product-card__image" alt="Can">
                                  <div class="product-card__content">
                                      <div class="product-card__title"><shopify-data query="product.title"></shopify-data></div>
                                      <div class="product-card__price"><shopify-money query="product.selectedOrFirstAvailableVariant.price"></shopify-money></div>
                                  </div>
                              </a>
                          </div>
                      </template>
                  </shopify-list-context>
              </shopify-store>
            {% endif %}

            {% for block in section.blocks %}
                <div class="product-card" {{ block.shopify_attributes }}>
                    {% if block.settings.image != blank %}
                      <img src="{{ block.settings.image | image_url: width: 600 }}" class="product-card__image">
                    {% endif %}
                    <div class="product-card__content">
                        <div class="product-card__title">{{ block.settings.title }}</div>
                        <div class="product-card__price">{{ block.settings.price }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Volt Products",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "// CATALOG_V1.0"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SELECT FUEL"
    },
    {
      "type": "text",
      "id": "storefront_domain",
      "label": "Storefront Domain",
      "default": "palashstor.myshopify.com"
    },
    {
      "type": "text",
      "id": "storefront_token",
      "label": "Storefront Access Token",
      "default": "7e706483ff729f77a768614acd45fdc0"
    },
    {
      "type": "text",
      "id": "storefront_country",
      "label": "Storefront Country",
      "default": "US"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to Show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "SYSTEM OVERLOAD"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$34.00"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Volt Products",
      "blocks": [
        { "type": "card", "settings": { "title": "SYSTEM OVERLOAD", "price": "$34.00" } },
        { "type": "card", "settings": { "title": "CRYOGENIC FREEZE", "price": "$34.00" } },
        { "type": "card", "settings": { "title": "NEON DRIVE", "price": "$34.00" } }
      ]
    }
  ]
}
{% endschema %}
