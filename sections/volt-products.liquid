<link rel="stylesheet" href="{{ 'products.css' | asset_url }}">

<section id="products" class="products-section">
    <div class="container-volt">
        <div class="volt-section-header">
            <div>
                <div class="section-label">{{ section.settings.label | default: '// CATALOG_V1.0' }}</div>
                <h2 class="section-headline">{{ section.settings.heading | default: 'SELECT FUEL' }}</h2>
            </div>
        </div>

        <div class="products-grid">
            {% if section.settings.collection != blank %}
              {% for product in section.settings.collection.products limit: section.settings.products_count %}
                <a href="{{ product.url }}" class="product-card" style="text-decoration:none;">
                    {% if product.featured_image %}
                      <img src="{{ product.featured_image | image_url: width: 600 }}" class="product-card__image" alt="{{ product.title | escape }}">
                    {% endif %}
                    <div class="product-card__content">
                        <div class="product-card__title">{{ product.title }}</div>
                        <div class="product-card__price">{{ product.price | money }}</div>
                    </div>
                </a>
              {% endfor %}
            {% else %}
              <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:rgba(255,255,255,0.4); grid-column:1/-1; text-align:center; padding:60px 0;">
                Select a collection in the section settings to display products.
              </p>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Volt Products",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "// CATALOG_V1.0"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SELECT FUEL"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to Show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Volt Products"
    }
  ]
}
{% endschema %}
